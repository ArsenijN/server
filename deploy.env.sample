# deploy.env — local deployment configuration
# Copy this file to deploy.env and fill in your values.
# This file is gitignored and never synced to the server.
#
# Usage:
#   Linux/macOS/Git Bash:  ./sync_to_server.sh
#   Windows (Git Bash):    bash sync_to_server.sh
#   Windows (batch):       sync_to_server.bat

# --- SSH connection ---
REMOTE_USER=arsen
REMOTE_HOST=arseniusgen.uk.to
REMOTE_PORT=2847

# Path to your SSH private key.
# Windows example: C:/Users/YourName/.ssh/id_ed25519
# Linux example:   /home/yourname/.ssh/DebianServerKey
SSH_KEY=${HOME}/DebianServerKey

# --- Remote paths ---
# Base directory on the server where the site lives.
# The Web/, TestWeb/ and services/ subdirectories will be synced under here.
REMOTE_SITE=~/servers/self-host/site

# The username the services run as on the remote host (used in .service files).
# After changing this you must re-run the deploy and reload systemd:
#   sudo systemctl daemon-reload
REMOTE_SERVICE_USER=arsen

# --- Local paths ---
# Where the server/ tree lives relative to the repo root.
# Default: ./server  (do not change unless you restructured the repo)
LOCAL_BASE=./server

# --- Sudo on the remote ---
# Set to 1 to skip the sudo password prompt (requires passwordless sudo on the
# remote for the systemctl restart commands, or an active sudo session).
NO_SUDO_PROMPT=0
